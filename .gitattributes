# Default: text files use LF line endings in the repo, regardless of platform.
* text=auto eol=lf

# Binary files — never apply line-ending conversion.
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.svg binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.tgz binary
*.bz2 binary
*.xz binary
*.7z binary
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary
*.eot binary
*.docx binary
*.xlsx binary
*.pptx binary
*.odt binary
*.ods binary
*.odp binary

# Generated assets (PDFs included): keep them out of diffs to reduce noise.
*.pdf -diff
*.png -diff
*.jpg -diff
*.jpeg -diff
