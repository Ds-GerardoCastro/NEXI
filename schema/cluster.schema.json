{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Ds-GerardoCastro/NEXI/schema/cluster.schema.json",
  "title": "NEXI cluster metadata",
  "description": "Schema for cluster.yaml — structured metadata for one NEXI cluster. A cluster is a coherent intelligence model: a system of co-dependent patterns that together solve a class of cognitive problems.",
  "type": "object",
  "required": [
    "id",
    "name",
    "status",
    "version",
    "problem_class",
    "member_nexis",
    "system_falsifiable_hypothesis"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Kebab-case slug. Must match the cluster's folder name."
    },
    "name": {
      "type": "string",
      "minLength": 2
    },
    "status": {
      "enum": ["template", "draft", "canonical", "deprecated"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "problem_class": {
      "type": "string",
      "minLength": 50,
      "description": "What class of cognitive problems this cluster addresses."
    },
    "member_nexis": {
      "type": "array",
      "minItems": 2,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      },
      "description": "Slugs of NEXI patterns that constitute this cluster. A cluster has at least 2 members."
    },
    "system_falsifiable_hypothesis": {
      "type": "string",
      "minLength": 80,
      "description": "A testable claim about the cluster's combined effect — distinct from the falsifiable hypotheses of individual member NEXIs. Required."
    },
    "natural_exemplars": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["species", "paper"],
        "additionalProperties": false,
        "properties": {
          "species": { "type": "string" },
          "paper": {
            "type": "object",
            "required": ["title"],
            "additionalProperties": false,
            "properties": {
              "title": { "type": "string" },
              "authors": { "type": "array", "items": { "type": "string" } },
              "venue": { "type": "string" },
              "date": { "type": "string" },
              "doi": { "type": "string" },
              "url": { "type": "string", "format": "uri" }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },
    "when_to_adopt": {
      "type": "string"
    },
    "when_not_to_adopt": {
      "type": "string"
    },
    "tradeoffs": {
      "type": "string"
    },
    "complementarity_notes": {
      "type": "string",
      "description": "How the member NEXIs work together — what each contributes, where the dependencies run."
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "vault_consolidation_hubs": {
          "type": "array",
          "items": { "type": "string" }
        },
        "vault_metamodels": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
